scoring:
  short_response_threshold: 800
  intro_char_fallback: 500
  edi:
    level_ratios:
      1: 0.25
      2: 0.5
      3: 1.0
    length_gate_chars: 200

# LLM endpoint for `traces calibrate judge` + `calibrate recommend`.
# `provider` references a key in `providers:` above; the transport-level
# fields (base_url, api_key, timeout, max_retries) live on the provider.
audit:
  provider: nvidia
  judge_model: "meta/llama-3.3-70b-instruct"
  proposer_model: "meta/llama-3.3-70b-instruct"
  temperature: 0.0
  top_p: 0.95
  max_tokens: 8192
  reasoning_effort: null
  parse_retries: 1

  # Parallel-scorer panel (used by `traces judge is`; `traces score judge`
  # remains as a compatibility alias).
  # Hard requirement: >= 2 entries, no member also in `models:` above.
  # Recommended consilium: 3 frontier judges from disjoint families
  # (Anthropic, OpenAI, DeepSeek) via the configured OpenRouter endpoint.
  # Fleiss' kappa is meaningful at 3, and family decorrelation reduces
  # shared failure modes. Empty list (or omitted) disables `traces judge is`
  # with a clear CLI error. If a judged run includes any of these same
  # provider/model pairs as benchmarked outputs, remove that member or
  # exclude the benchmarked model before running the judge.
  # judge_panel:
  #   - { provider: openrouter, model: anthropic/claude-sonnet-4.6 }
  #   - { provider: openrouter, model: openai/gpt-5.4 }
  #   - { provider: openrouter, model: deepseek/deepseek-v3.2 }

  # Per-judge per-call USD cost estimate. Used by `judge is`'s
  # --max-cost gate to estimate spend before dispatch; missing entries
  # fall back to default_per_call_usd ($0.05). Flat estimates only —
  # not actual token-billed cost.
  # cost_per_call_usd:
  #   "openrouter/anthropic/claude-sonnet-4.6": 0.05
  #   "openrouter/openai/gpt-5.4": 0.04
  #   "openrouter/deepseek/deepseek-v3.2": 0.03

  default_max_cost_usd: 50            # `--max-cost` default; pass 0 to disable
  panel_member_min_kappa: 0.5          # diagnostic threshold for per-judge κ vs deterministic floor
  harm_aggregation: max                # legacy no-op; retained for old configs

# Optional. When non-empty, `calibrate judge` runs each starred case
# through this fallback chain (in order) until one model returns a
# parseable verdict. Refusals / errors fall through to the next entry.
# Precedence: --judge-models flag > calibration.judge_models > [audit.judge_model].
# calibration:
#   judge_models:
#     - "deepseek-ai/deepseek-v4-pro"
#     - "meta/llama-3.3-70b-instruct"

reporting:
  output_dir: "results/"
  plot_format: "png"
  plot_dpi: 150
