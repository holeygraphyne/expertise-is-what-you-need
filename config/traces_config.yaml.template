# TRACES configuration template
# Copy to config/traces_config.yaml and set per-provider API keys in .env:
#   NVIDIA_API_KEY=...      (NVIDIA NIM)
#   OPENROUTER_API_KEY=...  (OpenRouter; needed even for free-tier models)
#   GROQ_API_KEY=...        (Groq)
# Each `providers.<name>.api_key` is auto-overridden by `<NAME_UPPER>_API_KEY`
# at load time, so the `${...}` literals below are documentation, not
# functional substitution. Setting only one key is fine — comment out the
# unused providers and the model rows that reference them.

corpus:
  root: "traces/corpus"

atlas:
  ontology_path: "../atlas-ontology/src/ontology/atlas.ttl"
  vocabularies_path: "../atlas-ontology/vocabularies/"

grobid:
  url: "http://localhost:8070"
  timeout: 120
  consolidate_header: 1
  consolidate_citations: 0

# Each entry under `providers:` is one OpenAI-compatible /v1/chat/completions
# endpoint. Models below reference a provider by name; `audit.provider`
# does the same. API keys are auto-overridden by per-provider env vars
# `<PROVIDER_NAME_UPPER>_API_KEY` (so the `${...}` literal is mostly
# cosmetic — the env var wins).
#
# These knobs are the TRANSPORT layer — one HTTP call at a time:
#   timeout        socket timeout for one request (seconds)
#   max_retries    per-call retry count on 429 / 5xx / network blips
#   retry_delay    linear backoff seconds between retries
#   rpm_limit      outgoing throttle (token-bucket); 0 disables
# They protect against transient failures on otherwise-healthy services.
# For persistent failures (a dead model, sustained outage), see the
# `pipeline.trip_thresholds` section below.
providers:
  nvidia:
    base_url: "https://integrate.api.nvidia.com/v1"
    api_key: "${NVIDIA_API_KEY}"
    timeout: 600
    max_retries: 3
    retry_delay: 3.0
    rpm_limit: 30
  openrouter:
    base_url: "https://openrouter.ai/api/v1"
    api_key: "${OPENROUTER_API_KEY}"
    timeout: 120
    max_retries: 3
    retry_delay: 3.0
    rpm_limit: 20            # free tier rate-limits per-model; 20 avoids 429 cascades
  groq:
    base_url: "https://api.groq.com/openai/v1"
    api_key: "${GROQ_API_KEY}"
    timeout: 120
    max_retries: 3
    retry_delay: 3.0
    rpm_limit: 30

pipeline:
  concurrency: 42
  checkpoint_interval: 10
  trip_thresholds:
    consecutive_failures: 5
    rate_window_size: 10
    rate_min_samples: 5
    rate_threshold: 0.7
    wallclock_no_success_seconds: 120.0

service_model:
  id: "meta/llama-4-maverick-17b-128e-instruct"

